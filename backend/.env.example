# Relative paths resolve against backend/ package root, not process CWD.
# Absolute paths are used as given. Adjust ARES_SIM_BINARY on non-Windows hosts
# (drop .exe or point at the built binary for that platform).
# Supported ARES_LOG_LEVEL values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# No API keys, NVIDIA settings, or secrets in Phase 1.
ARES_PROJECT_ROOT=..
ARES_SIM_BINARY=../Simulator/build/sim_core.exe
ARES_SCENARIO_DIR=../scenarios
ARES_RUNS_DIR=./data/runs
ARES_SIM_TIMEOUT_SECONDS=30
ARES_MAX_CONCURRENT_RUNS=2
ARES_LOG_LEVEL=INFO
