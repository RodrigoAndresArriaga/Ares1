# Relative paths resolve against backend/ package root, not process CWD.
# Absolute paths are used as given. Adjust ARES_SIM_BINARY on non-Windows hosts
# (drop .exe or point at the built binary for that platform).
# Supported ARES_LOG_LEVEL values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# No API keys, NVIDIA settings, or secrets in Phase 1/3.
ARES_PROJECT_ROOT=..
ARES_SIM_BINARY=../Simulator/build/sim_core.exe
ARES_SCENARIO_DIR=../scenarios
ARES_RUNS_DIR=./data/runs
# Mission session JSON root (created + writability-probed like runs)
ARES_SESSIONS_DIR=./data/sessions
ARES_SIM_TIMEOUT_SECONDS=30
ARES_MAX_CONCURRENT_RUNS=2
# Telemetry replay cadence bounds (milliseconds)
ARES_REPLAY_DEFAULT_INTERVAL_MS=250
ARES_REPLAY_MIN_INTERVAL_MS=25
ARES_REPLAY_MAX_INTERVAL_MS=60000
# Concurrent SSE replay stream limit (separate from simulator run semaphore)
ARES_MAX_REPLAY_STREAMS=20
# SSE keepalive interval while a client is connected
ARES_SSE_HEARTBEAT_SECONDS=15
ARES_LOG_LEVEL=INFO
